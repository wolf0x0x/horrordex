---
import siteConfig from "../data/site-config.json";

interface Props {
  label: string;
  slotId?: string;
}
const { label, slotId } = Astro.props;
---
<div class="ad-slot" aria-label={label}>
  <span>{label}</span>
  <small>Reserved static ad container</small>

  {slotId && (
    <>
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client={siteConfig.ads.client}
           data-ad-slot={slotId}
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
      <script>
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </>
  )}
</div>
