---
import siteConfig from "../data/site-config.json";

interface Props {
  label: string;
  slotId?: string;
  format?: "auto" | "rectangle" | "horizontal" | "vertical";
}
const { label, slotId, format = "auto" } = Astro.props;
---
<div class:list={["ad-slot", slotId ? "configured" : "empty"]} aria-label={label}>
  {!slotId && (
    <div class="ad-placeholder">
      <span>{label}</span>
      <small>Awaiting AdSense slot ID</small>
    </div>
  )}

  {slotId && (
    <>
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client={siteConfig.ads.client}
           data-ad-slot={slotId}
           data-ad-format={format}
           data-full-width-responsive="true"></ins>
      <script is:inline>
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </>
  )}
</div>
