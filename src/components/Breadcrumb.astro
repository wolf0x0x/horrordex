---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---
<nav aria-label="Breadcrumb" class="breadcrumb">
  <ol>
    {crumbs.map((crumb, index) => (
      <li>
        {index > 0 && <span aria-hidden="true"> / </span>}
        {crumb.href ? (
          <a href={crumb.href}>{crumb.label}</a>
        ) : (
          <span aria-current="page">{crumb.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
