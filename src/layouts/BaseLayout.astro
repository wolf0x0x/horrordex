---
import { getCollection } from "astro:content";
import siteConfig from "../data/site-config.json";

interface Props {
  title: string;
  description: string;
  current?: "matrix" | "entity" | "guide";
}

const { title, description, current = "matrix" } = Astro.props;
const [entities, guides] = await Promise.all([
  getCollection("entities"),
  getCollection("guides")
]);
const navEntity = entities.find((entry) => entry.data.entityId === siteConfig.navigation.entityId) ?? entities.find((entry) => entry.data.featured) ?? entities[0];
const navGuide = guides.find((entry) => entry.data.guideId === siteConfig.navigation.guideId) ?? guides.find((entry) => entry.data.featured) ?? guides[0];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content={siteConfig.seo.themeColor} />
    <link rel="icon" type="image/svg+xml" href={siteConfig.icons.favicon} />
    <link rel="icon" type="image/png" sizes="32x32" href={siteConfig.icons.favicon32} />
    <link rel="shortcut icon" type="image/png" href={siteConfig.icons.shortcutIcon} />
    <link rel="apple-touch-icon" href={siteConfig.icons.appleTouchIcon} />
    <link rel="mask-icon" href={siteConfig.icons.maskIcon} color={siteConfig.seo.themeColor} />
    <link rel="manifest" href={siteConfig.icons.manifest} />
    <link rel="stylesheet" href="/assets/styles/site.css" />
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.ads.client}`}
            crossorigin="anonymous"></script>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.analytics.measurementId}`}></script>
    <script is:inline define:vars={{ measurementId: siteConfig.analytics.measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", measurementId);
    </script>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label={`${siteConfig.brand.name} home`}>
        <span class="brand-mark">{siteConfig.brand.mark}</span>
        <span class="brand-text">
          <strong>{siteConfig.brand.domain.toUpperCase()}</strong>
          <span>{siteConfig.brand.tagline}</span>
        </span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" aria-current={current === "matrix" ? "page" : undefined}>Matrix</a>
        {navEntity && <a href={`/entities/${navEntity.slug}/`} aria-current={current === "entity" ? "page" : undefined}>Dossier: {navEntity.data.title.split("//")[0].trim()}</a>}
        {navGuide && <a href={`/guides/${navGuide.slug}/`} aria-current={current === "guide" ? "page" : undefined}>{navGuide.data.title}</a>}
      </nav>
    </header>
    <slot />
    <footer class="footer">
      {siteConfig.brand.footer}
    </footer>
  </body>
</html>
