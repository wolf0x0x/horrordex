---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import EntityCard from "../components/EntityCard.astro";
import AdSlot from "../components/AdSlot.astro";
import stats from "../data/roblox-stats.json";
import siteConfig from "../data/site-config.json";

const entities = await getCollection("entities");
const guides = await getCollection("guides");
const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
const totalPopulation = Object.values(stats).reduce((sum, item) => sum + Number(item.live_population || 0), 0);
const featuredEntity = entities.find((entry) => entry.data.entityId === siteConfig.hero.featuredEntityId) ?? entities.find((entry) => entry.data.featured) ?? entities[0];
const primaryGuide = guides.find((entry) => entry.data.guideId === siteConfig.hero.primaryGuideId) ?? guides.find((entry) => entry.data.featured) ?? guides[0];
const sortedEntities = [...entities].sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const origins = [...new Set([
  ...entities.map((entry) => entry.data.gameSource),
  ...guides.map((entry) => entry.data.topic)
])];
const originCategories = origins.map((origin) => ({
  name: origin,
  href: `/categories/${slugify(origin)}/`
}));
const severities = [
  { label: "Safe", value: "green" },
  { label: "Hostile", value: "amber" },
  { label: "Fatal", value: "red" }
];
---
<BaseLayout
  title={siteConfig.seo.homeTitle}
  description={siteConfig.seo.homeDescription}
  current="matrix"
>
  <main class="site-shell">
    <section class="hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">SYS_ACTIVE / static bake {new Date().toISOString().slice(0, 10)}</p>
        <h1 id="page-title">Entity <span>Matrix</span></h1>
        <p class="lead">
          A pure static horror database for Roblox anomalies, Backrooms entities, and longform escape guides. Content lives in Git, telemetry is baked into JSON, and Cloudflare Pages serves the finished HTML from the edge.
        </p>
        <div class="hero-actions">
          <a class="terminal-button" href="#matrix">Open matrix</a>
          {primaryGuide && <a class="terminal-button" href={`/guides/${primaryGuide.slug}/`}>Read featured guide</a>}
        </div>
      </div>
      <figure class="hero-media">
        <img src={siteConfig.hero.image ?? featuredEntity?.data.image} alt={`${siteConfig.brand.name} featured dossier visual`} />
        <figcaption class="caption-strip">
          <span>{siteConfig.hero.caption ?? featuredEntity?.data.route ?? "featured dossier"}</span>
          <span>LIVE {totalPopulation.toLocaleString("en-US")}</span>
        </figcaption>
      </figure>
    </section>

    <section class="stats-grid" aria-label="MVP telemetry">
      <div class="stat"><strong>{entities.length}</strong><span>Entity records</span></div>
      <div class="stat"><strong>{guides.length}</strong><span>Survival guides</span></div>
      <div class="stat"><strong>{totalPopulation.toLocaleString("en-US")}</strong><span>Players baked in</span></div>
      <div class="stat"><strong>0</strong><span>Runtime servers</span></div>
    </section>

    <div class="matrix-layout" id="matrix">
      <aside class="panel" aria-label="Matrix controls">
        <div class="panel-title"><span>Input parameters</span><span>v0.1</span></div>
        <input class="input" type="search" placeholder="LOCATE_ENTITY..." aria-label="Search records" data-record-search />
        <div class="filter-stack">
          {originCategories.map((origin) => (
            <label class="check-row">
              <input type="checkbox" value={origin.name} checked data-origin-filter />
              <span>{origin.name}</span>
              <a href={origin.href} aria-label={`Open ${origin.name} category`}>category</a>
            </label>
          ))}
        </div>
        <div class="badge-row">
          {severities.map((severity) => (
            <label class:list={["risk-tag", severity.value]}><input type="checkbox" value={severity.value} checked data-severity-filter /> {severity.label}</label>
          ))}
        </div>
        <AdSlot label="AdSense native banner 336x280" slotId={siteConfig.ads.slots.sidebarNative} />
      </aside>

      <section aria-labelledby="matrix-title">
        <div class="section-head">
          <h2 id="matrix-title">Classified Records</h2>
          <p class="micro">source: src/content + src/data/roblox-stats.json</p>
        </div>
        <div class="entity-grid">
          {sortedEntities.map((entry) => (
            <EntityCard
              title={entry.data.title}
              href={`/entities/${entry.slug}/`}
              recordId={entry.data.entityId}
              image={entry.data.image}
              summary={entry.data.summary}
              hazardLevel={entry.data.hazardLevel}
              source={entry.data.gameSource}
              categoryHref={`/categories/${slugify(entry.data.gameSource)}/`}
              visualEffect={entry.data.visualEffect}
              population={stats[entry.data.entityId]?.live_population}
              featured={entry.data.featured}
            />
          ))}
          {guides.map((entry) => (
            <EntityCard
              title={entry.data.title}
              href={`/guides/${entry.slug}/`}
              recordId={entry.data.guideId}
              image={entry.data.image}
              summary={entry.data.summary}
              hazardLevel={entry.data.hazardLevel}
              source={entry.data.topic}
              categoryHref={`/categories/${slugify(entry.data.topic)}/`}
              population={stats[entry.data.guideId]?.live_population}
            />
          ))}
        </div>
        <div class="pager" aria-label="Matrix pagination">
          <button type="button" class="terminal-button" data-page-prev>Previous</button>
          <span class="micro" data-page-status>Page 1 / 1</span>
          <button type="button" class="terminal-button" data-page-next>Next</button>
        </div>
        <p class="empty-state" data-empty-state hidden>No records match this filter.</p>
      </section>
    </div>
  </main>
  <script is:inline>
    const pageSize = 6;
    const search = document.querySelector("[data-record-search]");
    const originFilters = Array.from(document.querySelectorAll("[data-origin-filter]"));
    const severityFilters = Array.from(document.querySelectorAll("[data-severity-filter]"));
    const cards = Array.from(document.querySelectorAll("[data-record-card]"));
    const prevButton = document.querySelector("[data-page-prev]");
    const nextButton = document.querySelector("[data-page-next]");
    const pageStatus = document.querySelector("[data-page-status]");
    const emptyState = document.querySelector("[data-empty-state]");
    let activePage = 1;

    function selectedValues(inputs) {
      return new Set(inputs.filter((input) => input.checked).map((input) => input.value));
    }

    function setCheckedFromParam(inputs, values) {
      if (!values.size) return;
      for (const input of inputs) {
        input.checked = values.has(input.value);
      }
    }

    function readStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      search.value = params.get("q") ?? "";
      setCheckedFromParam(originFilters, new Set((params.get("origin") ?? "").split(",").filter(Boolean)));
      setCheckedFromParam(severityFilters, new Set((params.get("severity") ?? "").split(",").filter(Boolean)));
      activePage = Math.max(1, Number(params.get("page") ?? 1) || 1);
    }

    function writeStateToUrl(totalPages) {
      const params = new URLSearchParams();
      const query = search.value.trim();
      const origins = [...selectedValues(originFilters)];
      const severities = [...selectedValues(severityFilters)];
      const boundedPage = Math.min(Math.max(activePage, 1), totalPages);

      if (query) params.set("q", query);
      if (origins.length && origins.length !== originFilters.length) params.set("origin", origins.join(","));
      if (severities.length && severities.length !== severityFilters.length) params.set("severity", severities.join(","));
      if (boundedPage > 1) params.set("page", String(boundedPage));

      const queryString = params.toString();
      const nextUrl = `${window.location.pathname}${queryString ? `?${queryString}` : ""}${window.location.hash || "#matrix"}`;
      window.history.replaceState(null, "", nextUrl);
    }

    function applyFilters({ updateUrl = true } = {}) {
      const query = (search?.value ?? "").trim().toLowerCase();
      const origins = selectedValues(originFilters);
      const severities = selectedValues(severityFilters);
      const matches = [];

      for (const card of cards) {
        const searchable = `${card.dataset.recordTitle} ${card.dataset.recordSummary}`;
        const matchesQuery = !query || searchable.includes(query);
        const matchesOrigin = origins.has(card.dataset.recordOrigin);
        const matchesSeverity = severities.has(card.dataset.recordSeverity);
        if (matchesQuery && matchesOrigin && matchesSeverity) {
          matches.push(card);
        }
        card.hidden = true;
      }

      const totalPages = Math.max(1, Math.ceil(matches.length / pageSize));
      activePage = Math.min(Math.max(activePage, 1), totalPages);
      const start = (activePage - 1) * pageSize;
      for (const card of matches.slice(start, start + pageSize)) {
        card.hidden = false;
      }

      pageStatus.textContent = `Page ${activePage} / ${totalPages} · ${matches.length} records`;
      prevButton.disabled = activePage <= 1;
      nextButton.disabled = activePage >= totalPages;
      emptyState.hidden = matches.length > 0;

      if (updateUrl) writeStateToUrl(totalPages);
    }

    readStateFromUrl();
    applyFilters({ updateUrl: false });

    search?.addEventListener("input", () => {
      activePage = 1;
      applyFilters();
    });
    for (const input of [...originFilters, ...severityFilters]) {
      input.addEventListener("change", () => {
        activePage = 1;
        applyFilters();
      });
    }
    prevButton?.addEventListener("click", () => {
      activePage -= 1;
      applyFilters();
    });
    nextButton?.addEventListener("click", () => {
      activePage += 1;
      applyFilters();
    });
  </script>
</BaseLayout>
