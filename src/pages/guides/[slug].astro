---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import stats from "../../data/roblox-stats.json";
import siteConfig from "../../data/site-config.json";
import siteConfig from "../../data/site-config.json";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const entities = await getCollection("entities");
const relatedEntities = entities.filter((entity) => entry.data.relatedEntityIds.includes(entity.data.entityId));
const telemetry = stats[entry.data.guideId] ?? null;
---
<BaseLayout
  title={`${entry.data.title} | ${siteConfig.seo.guideTitleSuffix}`}
  description={entry.data.summary}
  current="guide"
>
  <main class="site-shell">
    <figure class="hero-media guide-hero">
      <img src={entry.data.image} alt={`${entry.data.title} visual reference`} />
      <figcaption class="caption-strip">
        <span>{entry.data.topic} / {entry.data.hazardLevel}</span>
        <span>UPDATED {entry.data.updated}</span>
      </figcaption>
    </figure>

    <section class="guide-layout">
      <article class="article-body">
        <p class="eyebrow">SURVIVAL ARTICLE / {entry.data.guideId}</p>
        <h1>{entry.data.title.replace("Guide:", "Guide: ")} </h1>
        <p class="lead">{entry.data.summary}</p>
        <Content />

        {entry.data.assetCredits.length > 0 && (
          <>
            <h2>Downloaded Assets & Attribution</h2>
            <div class="resource-list">
              {entry.data.assetCredits.map((asset) => (
                <p><strong>{asset.title}</strong> by {asset.creator}, licensed {asset.license}. Source: <a href={asset.source}>{asset.source}</a></p>
              ))}
            </div>
          </>
        )}
      </article>

      <aside class="toc" aria-label="Guide metadata">
        <div class="panel-title"><span>Guide fields</span><span>static</span></div>
        <div class="data-table">
          <div class="data-row"><span>Topic</span><strong>{entry.data.topic}</strong></div>
          <div class="data-row"><span>Risk</span><strong>{entry.data.hazardLevel}</strong></div>
          <div class="data-row"><span>Guide ID</span><strong>{entry.data.guideId}</strong></div>
          <div class="data-row"><span>Interest</span><strong id={`live-${entry.data.guideId}`}>{telemetry?.live_population?.toLocaleString("en-US") ?? "offline"}</strong></div>
          <div class="data-row"><span>Sync</span><strong id={`sync-${entry.data.guideId}`}>{telemetry?.last_mutation_sync ?? "offline"}</strong></div>
        </div>
        <a href="/">Return to matrix</a>
        {relatedEntities.map((entity) => <a href={`/entities/${entity.slug}/`}>Related: {entity.data.title}</a>)}
        <AdSlot label="AdSense sticky sidebar 300x600" slotId={siteConfig.ads.slots.stickySidebar} />
      </aside>
    </section>
  </main>
</BaseLayout>
